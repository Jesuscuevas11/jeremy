{%- comment -%}
  Renders ticker block content. Used for infinite scroll - render twice for seamless loop.
  Usage: {% render 'announcement-ticker-blocks', section: section, iterations: 15 %}
{%- endcomment -%}
{%- for i in (1..iterations) -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'announcement' -%}
      {%- if block.settings.text != blank -%}
        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}" class="announcement-bar__link link link--text focus-inset animate-arrow">
        {%- endif -%}
        <p class="announcement-bar__message announcement-bar__message-{{ block.id }} h5" style="display: inline-flex; padding: 0 2rem; min-height: fit-content;" {{ block.shopify_attributes }}>
          {% if block.settings.custom_image != blank %}
            <div class="announcement-bar__custom-image announcement-bar__custom-image-{{ block.id }}">
              <img src="{{ block.settings.custom_image | image_url: width: 200 }}" 
                   alt="{{ block.settings.text | escape }}"
                   loading="eager"
                   width="{{ block.settings.custom_image_height }}"
                   height="{{ block.settings.custom_image_height }}"
                   style="max-width: 100%; max-height: {{ block.settings.custom_image_height }}px; height: {{ block.settings.custom_image_height }}px; width: auto; object-fit: contain;">
            </div>
          {% elsif block.settings.icon != 'none' %}
            {% render 'icon-accordion', icon: block.settings.icon %}
          {% endif %}
          <span style="color: {{ block.settings.text_color }};">{{ block.settings.text }}</span>
          {%- if block.settings.link != blank -%}
            {{- 'icon-arrow.svg' | inline_asset_content -}}
          {%- endif -%}
        </p>
        {%- if block.settings.link != blank -%}
          </a>
        {%- endif -%}
      {%- endif -%}
    {%- endif -%}
    {%- if block.type == 'image_announcement' -%}
      {%- if block.settings.image != blank -%}
        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}" class="announcement-bar__link link focus-inset">
        {%- endif -%}
        <div class="announcement-bar__image announcement-bar__image-{{ block.id }}">
          {%- assign img_size = block.settings.image_height | times: 5 -%}
          {{ block.settings.image | image_url: width: img_size | image_tag:
            loading: 'eager',
            width: img_size,
            height: block.settings.image_height
          }}
        </div>
        {%- if block.settings.link != blank -%}
          </a>
        {%- endif -%}
      {%- endif -%}
    {%- endif -%}
    {%- if block.type == 'button' -%}
      {%- if block.settings.text != blank -%}
        <a href="{{ block.settings.link }}" class="announcement-bar__button-{{ block.id }}" {{ block.shopify_attributes }}>
          {{ block.settings.text | escape }}
          {% if block.settings.show_arrow %} {{- 'icon-arrow.svg' | inline_asset_content -}} {% endif %}
        </a>
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
{%- endfor -%}
