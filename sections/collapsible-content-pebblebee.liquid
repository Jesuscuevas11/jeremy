<style>
  /* --- Padding --- */
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}rem;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}rem;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_tablet }}rem;
      padding-bottom: {{ section.settings.padding_bottom_tablet }}rem;
    }
  }
  @media screen and (min-width: 1440px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_desktop }}rem;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}rem;
    }
  }

  /* --- Container --- */
  #shopify-section-{{ section.id }} .container {
    width: 100%;
    padding-left: 2rem;
    padding-right: 2rem;
    margin-left: auto;
    margin-right: auto;
  }
  @media screen and (min-width: 1200px) {
    #shopify-section-{{ section.id }} .container {
      padding-left: 8rem;
      padding-right: 8rem;
      max-width: calc(1064px + 16rem);
    }
  }

  /* --- Section title --- */
  #shopify-section-{{ section.id }} .collapsible-content__titles {
    display: flex;
    flex-direction: column;
    align-items: {{ section.settings.heading_alignment }};
    text-align: {{ section.settings.heading_alignment }};
    margin-bottom: 3.2rem;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .collapsible-content__titles {
      margin-bottom: 4rem;
    }
  }
  #shopify-section-{{ section.id }} .collapsible-content__title {
    font-family: Poppins, sans-serif;
    font-size: 2.52rem;
    font-weight: 700;
    color: rgb(42, 42, 42);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .collapsible-content__title {
      font-size: 2.94rem;
    }
  }
  @media screen and (min-width: 990px) {
    #shopify-section-{{ section.id }} .collapsible-content__title {
      font-size: 3.36rem;
    }
  }
  @media screen and (min-width: 1360px) {
    #shopify-section-{{ section.id }} .collapsible-content__title {
      font-size: 4.2rem;
    }
  }

  /* --- Items list --- */
  #shopify-section-{{ section.id }} .collapsible-content__items {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }

  /* --- Individual item card --- */
  #shopify-section-{{ section.id }} .collapsible-content__item {
    overflow: hidden;
    background-color: rgb(var(--color-background, 255, 255, 255));
    padding: 2.4rem;
    cursor: pointer;
    border-radius: 1rem;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .collapsible-content__item {
      padding: 2.4rem 2.6rem 2.4rem 4rem;
    }
  }
  @media screen and (hover: hover) and (pointer: fine) {
    #shopify-section-{{ section.id }} .collapsible-content__item:hover:not(.active) .collapsible-content__question {
      opacity: var(--hover-opacity, 0.7);
    }
  }

  /* --- Active item states --- */
  #shopify-section-{{ section.id }} .collapsible-content__item.active .collapsible-content__icon svg {
    transform: rotate(45deg);
  }
  #shopify-section-{{ section.id }} .collapsible-content__item.active .collapsible-content__toggle {
    padding-bottom: 1.6rem;
  }
  #shopify-section-{{ section.id }} .collapsible-content__item.active .collapsible-content__answer {
    transition: all 0.4s ease;
  }
  #shopify-section-{{ section.id }} .collapsible-content__item.active .collapsible-content__answer p {
    height: auto;
    opacity: 1;
    transition: height 0.4s ease, opacity 0.4s ease;
  }

  /* --- Toggle button --- */
  #shopify-section-{{ section.id }} .collapsible-content__toggle {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    column-gap: 1.6rem;
    width: 100%;
    cursor: pointer;
    transition: all 0.4s ease;
    padding-bottom: 0;
    background: none;
    border: none;
    text-align: left;
  }
  #shopify-section-{{ section.id }} .collapsible-content__toggle-group {
    display: flex;
    align-items: center;
  }

  /* --- Question text --- */
  #shopify-section-{{ section.id }} .collapsible-content__question {
    margin: 0;
    text-align: left;
    word-break: break-word;
    transition: opacity var(--duration-default, 0.3s);
    font-family: Poppins, sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: rgb(42, 42, 42);
    line-height: 1.4;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .collapsible-content__question {
      font-size: 1.7rem;
    }
  }

  /* --- +/× icon --- */
  #shopify-section-{{ section.id }} .collapsible-content__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
    padding: 0.2rem;
  }
  #shopify-section-{{ section.id }} .collapsible-content__icon svg {
    transition: transform var(--duration-default, 0.3s);
    transform: rotate(-90deg);
    width: 1.4rem;
    height: 1.4rem;
    color: rgb(var(--color-foreground, 42, 42, 42));
  }
  [data-scheme="dark"] #shopify-section-{{ section.id }} .collapsible-content__icon svg {
    color: #fff;
  }

  /* --- Answer panel --- */
  #shopify-section-{{ section.id }} .collapsible-content__answer {
    margin: 0;
    transition: all 0.4s ease;
  }
  #shopify-section-{{ section.id }} .collapsible-content__answer p {
    height: 0;
    opacity: 0;
    max-width: 71.2rem;
    color: rgb(var(--color-foreground-secondary, 90, 90, 90));
    transition: height 0.4s ease, opacity 0.4s ease;
    word-break: break-word;
    font-family: 'Source Sans Pro', sans-serif;
    font-size: 1.4rem;
    line-height: 1.6;
    margin: 0;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .collapsible-content__answer p {
      font-size: 1.6rem;
    }
  }
  #shopify-section-{{ section.id }} .collapsible-content__answer.rte * {
    margin-left: unset !important;
    margin-right: unset !important;
    color: rgb(var(--color-foreground-secondary, 90, 90, 90)) !important;
  }
  #shopify-section-{{ section.id }} .collapsible-content__answer.rte ol,
  #shopify-section-{{ section.id }} .collapsible-content__answer.rte ul {
    list-style-position: inside;
  }
  #shopify-section-{{ section.id }} .collapsible-content__answer.rte ul {
    list-style-type: disc;
  }
  #shopify-section-{{ section.id }} .collapsible-content__answer.rte ul li {
    list-style: inherit;
  }
  #shopify-section-{{ section.id }} .collapsible-content__answer.rte ol {
    list-style-type: decimal;
  }
</style>

<div class="collapsible-content background section-{{ section.id }}-padding" style="background-color: {{ section.settings.background_color }};">
  <div class="container">

    {%- if section.settings.title != blank -%}
      <div class="collapsible-content__titles">
        <h2 class="collapsible-content__title">{{ section.settings.title | escape }}</h2>
      </div>
    {%- endif -%}

    <div class="collapsible-content__content">
      <div class="collapsible-content__items">
        {%- for block in section.blocks -%}
          {%- if block.type == 'collapsible_row' -%}
            <div
              class="collapsible-content__item color-background-1{% if forloop.first and section.settings.open_first %} active{% endif %}"
              {{ block.shopify_attributes }}
            >
              <button class="collapsible-content__toggle button--unstyled focus-inset" type="button">
                <div class="collapsible-content__toggle-group">
                  <h3 style="font-size: unset; margin: 0;">
                    <p class="collapsible-content__question">{{ block.settings.question | escape }}</p>
                  </h3>
                </div>
                <div class="collapsible-content__icon">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M8 1V15M15 8L1 8" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/>
                  </svg>
                </div>
              </button>
              <div
                class="collapsible-content__answer rte rte__container"
                {%- unless forloop.first and section.settings.open_first %} style="display: none;"{% endunless %}
              >
                {{ block.settings.answer }}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

  </div>
</div>

<script>
(function () {
  var slideUp = function (element, duration) {
    if (!element) return;
    duration = duration || 300;
    element.style.height = element.scrollHeight + 'px';
    element.style.overflow = 'hidden';
    element.style.transition = 'height ' + duration + 'ms ease';
    requestAnimationFrame(function () { element.style.height = '0'; });
    setTimeout(function () {
      element.style.display = 'none';
      element.style.removeProperty('height');
      element.style.removeProperty('overflow');
      element.style.removeProperty('transition');
    }, duration);
  };

  var slideDown = function (element, duration) {
    if (!element) return;
    duration = duration || 300;
    element.style.removeProperty('display');
    var display = window.getComputedStyle(element).display;
    if (display === 'none') display = 'block';
    element.style.display = display;
    var height = element.scrollHeight;
    element.style.height = '0';
    element.style.overflow = 'hidden';
    element.style.transition = 'height ' + duration + 'ms ease';
    requestAnimationFrame(function () { element.style.height = height + 'px'; });
    setTimeout(function () {
      element.style.removeProperty('height');
      element.style.removeProperty('overflow');
      element.style.removeProperty('transition');
    }, duration);
  };

  var toggleCollapsible = function (event, toggles) {
    if (!toggles) return;
    var clicked = event.currentTarget;
    var answer = clicked.querySelector('.collapsible-content__answer');
    var activeItem = Array.from(toggles).find(function (item) {
      return item.classList.contains('active');
    });

    if (clicked !== activeItem) {
      if (activeItem) {
        activeItem.classList.remove('active');
        slideUp(activeItem.querySelector('.collapsible-content__answer'));
      }
      clicked.classList.add('active');
      slideDown(answer);
    } else {
      clicked.classList.remove('active');
      slideUp(answer);
    }
  };

  var initCollapsibleContent = function (sectionEl) {
    if (!sectionEl || !sectionEl.classList.contains('collapsible-content-section')) return;
    var items = sectionEl.querySelectorAll('.collapsible-content__item');
    items.forEach(function (item) {
      item.addEventListener('click', function (event) {
        toggleCollapsible(event, items);
      });
    });
  };

  /* Init on page load */
  var currentSection = document.currentScript.closest('.collapsible-content-section');
  initCollapsibleContent(currentSection);

  /* Re-init when section reloads in the Theme Editor */
  document.addEventListener('shopify:section:load', function (event) {
    initCollapsibleContent(event.target);
  });
})();
</script>

{% schema %}
{
  "name": "FAQ — Collapsible",
  "tag": "section",
  "class": "collapsible-content-section spaced-section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título de la sección",
      "default": "FAQs"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Alineación del título",
      "options": [
        { "value": "flex-start", "label": "Izquierda" },
        { "value": "center",     "label": "Centro" },
        { "value": "flex-end",   "label": "Derecha" }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "open_first",
      "label": "Abrir primer item por defecto",
      "default": true
    },
    {
      "type": "header",
      "content": "Padding — Móvil"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 20,
      "step": 0.4,
      "unit": "rem",
      "label": "Padding top",
      "default": 4
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 20,
      "step": 0.4,
      "unit": "rem",
      "label": "Padding bottom",
      "default": 6.4
    },
    {
      "type": "header",
      "content": "Padding — Tablet (≥750px)"
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "min": 0,
      "max": 20,
      "step": 0.4,
      "unit": "rem",
      "label": "Padding top",
      "default": 5.6
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "min": 0,
      "max": 20,
      "step": 0.4,
      "unit": "rem",
      "label": "Padding bottom",
      "default": 8.8
    },
    {
      "type": "header",
      "content": "Padding — Desktop (≥1440px)"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 20,
      "step": 0.4,
      "unit": "rem",
      "label": "Padding top",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 20,
      "step": 0.4,
      "unit": "rem",
      "label": "Padding bottom",
      "default": 14
    }
  ],
  "blocks": [
    {
      "type": "collapsible_row",
      "name": "Pregunta y Respuesta",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Pregunta",
          "default": "¿Pregunta frecuente?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Respuesta",
          "default": "<p>Escribe aquí la respuesta a esta pregunta frecuente.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ — Collapsible",
      "blocks": [
        {
          "type": "collapsible_row",
          "settings": {
            "question": "¿Este tracker funciona con Android e iOS?",
            "answer": "<p>Sí, el Pebblebee Clip 5 es compatible con Apple Find My en iOS y con Google Find Hub en Android. Esa compatibilidad multiplataforma significa que un solo Clip 5 funciona en cualquier sistema.</p>"
          }
        },
        {
          "type": "collapsible_row",
          "settings": {
            "question": "¿Cuánto dura la batería?",
            "answer": "<p>El Pebblebee Clip 5 tiene una autonomía de hasta 12 meses con una sola carga USB-C. Su diseño recargable elimina las pilas de botón desechables.</p>"
          }
        },
        {
          "type": "collapsible_row",
          "settings": {
            "question": "¿Cuál es el alcance Bluetooth?",
            "answer": "<p>El Pebblebee Clip 5 mantiene conexión Bluetooth directa hasta aproximadamente 500 pies (≈150 m) en espacio abierto, casi el doble que muchos competidores.</p>"
          }
        },
        {
          "type": "collapsible_row",
          "settings": {
            "question": "¿Pebblebee tiene acceso a mi ubicación?",
