{{ 'section-multicolumn-alert.css' | asset_url | stylesheet_tag }}
{{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}
<script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'multicolumn-alert.js' | asset_url }}" defer="defer"></script>

<section class="multicolumn-alert-section" data-section-id="{{ section.id }}">
  <div class="multicolumn-alert-padding">

    <div class="multicolumn color-background-2 background" data-enable-mobile-slider="true" data-enable-desktop-slider="false" data-space-between="1.6">

      <!-- Header -->
      <div class="multicolumn__header__titles titles titles--left">
        <div class="multicolumn__header__subtitle subtitle">{{ section.settings.subtitle }}</div>
        <h2 class="multicolumn__header__title title h2 size--h2">{{ section.settings.title }}</h2>
      </div>
      <div class="multicolumn__header__description description description--left">{{ section.settings.description }}</div>

      <!-- Grid (becomes Swiper on mobile) -->
      <div class="content multicolumn-grid swiper swiper--multicolumn">
        <div class="multicolumn-grid__wrapper multicolumn-grid__wrapper--3 swiper-wrapper">

          <!-- Card 1 -->
          <div class="multicolumn-card color-background-1 multicolumn-card--with-paddings multicolumn-card--border">
            <div class="multicolumn-card__inner multicolumn-card__inner--hor-align-left multicolumn-card__inner--ver-align-justify">
              <div class="multicolumn-card__inner-top">
                <h3 class="multicolumn-card__heading h4 multicolumn-card__heading--font-heading">
                  <span>1. Activación mediante pulsación rápida</span>
                </h3>
                <p class="multicolumn-card__text multicolumn-card__text--primary">Presiona el botón del Clip varias veces en rápida sucesión.</p>
              </div>
              <div class="multicolumn-card__inner-bottom">
              </div>
            </div>
          </div>

          <!-- Card 2 -->
          <div class="multicolumn-card color-background-1 multicolumn-card--with-paddings multicolumn-card--border">
            <div class="multicolumn-card__inner multicolumn-card__inner--hor-align-left multicolumn-card__inner--ver-align-justify">
              <div class="multicolumn-card__inner-top">
                <h3 class="multicolumn-card__heading h4 multicolumn-card__heading--font-heading">
                  <span>2. Sirena y Estroboscópico</span>
                </h3>
                <p class="multicolumn-card__text multicolumn-card__text--primary">El Clip emite inmediatamente una fuerte sirena y parpadea con LEDs para atraer la atención.</p>
              </div>
              <div class="multicolumn-card__inner-bottom">
              </div>
            </div>
          </div>

          <!-- Card 3 -->
          <div class="multicolumn-card color-background-1 multicolumn-card--with-paddings multicolumn-card--border">
            <div class="multicolumn-card__inner multicolumn-card__inner--hor-align-left multicolumn-card__inner--ver-align-justify">
              <div class="multicolumn-card__inner-top">
                <h3 class="multicolumn-card__heading h4 multicolumn-card__heading--font-heading">
                  <span>3. Safety Circle Ping</span>
                </h3>
                <p class="multicolumn-card__text multicolumn-card__text--primary">La aplicación envía tu ubicación a tu Círculo de Seguridad vía SMS.</p>
              </div>
              <div class="multicolumn-card__inner-bottom">
              </div>
            </div>
          </div>

        </div>

        <!-- Mobile prev/next buttons -->
        <div class="multicolumn-buttons no-js-hidden">
          <button class="multicolumn-button multicolumn-button--prev">
            <svg width="36" height="36" class="icon icon-arrow" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" focusable="false" role="presentation"><path d="M3 18L33 18M33 18L20.1429 6M33 18L20.1429 30" stroke="currentColor" stroke-width="2" stroke-linecap="square"/></svg>
          </button>
          <button class="multicolumn-button multicolumn-button--next">
            <svg width="36" height="36" class="icon icon-arrow" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" focusable="false" role="presentation"><path d="M3 18L33 18M33 18L20.1429 6M33 18L20.1429 30" stroke="currentColor" stroke-width="2" stroke-linecap="square"/></svg>
          </button>
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Meet Alert",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Nueva función de seguridad personal"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Meet Alert"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Alert, a free feature inside every Pebblebee Clip, turns an ordinary key ring into a lifeline: rapid presses activate a strobe, blasts a siren, and sends your location straight to the people you trust."
    }
  ],
  "presets": [
    {
      "name": "Meet Alert"
    }
  ]
}
{% endschema %}
