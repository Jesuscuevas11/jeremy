<style>
  /* ============================================================
     section-compare.css — extraído de Pebblebee t/106
  ============================================================ */
  img-comparison-slider{visibility:hidden}
  img-comparison-slider [slot=second]{display:none}
  img-comparison-slider.rendered{visibility:inherit}
  img-comparison-slider.rendered [slot=second]{display:unset}
  .compare{overflow:hidden}
  .compare__wrapper--split{display:flex;flex-direction:column}
  @media(min-width:990px){.compare__wrapper--split{flex-direction:row}}
  .compare__images{position:relative;width:100%;display:flex;flex-direction:row;border-radius:var(--border-radius-block);overflow:hidden}
  .compare__images:after{content:"";display:block;width:0;padding-bottom:var(--padding-bottom-mobile)}
  @media(min-width:576px){.compare__images:after{padding-bottom:var(--padding-bottom-desktop)}}
  .compare img-comparison-slider{-webkit-user-select:none;user-select:none;position:absolute;top:0;right:0;bottom:0;left:0;width:100%;height:100%;overflow:hidden;border-radius:var(--border-radius-block);outline:none}
  .compare img-comparison-slider .second{position:absolute;top:0;right:0;bottom:0;left:0;width:100%;height:100%}
  .compare img-comparison-slider .divider:after{border-left-color:rgb(var(--color-background,255,255,255))}
  .compare__figure{position:absolute;top:0;right:0;bottom:0;left:0;display:flex;margin:0;padding:0;width:100%;height:100%;background-color:rgb(var(--color-background-secondary,245,245,245))}
  .compare__figure-image{width:100%;height:100%;position:absolute;top:0;right:0;bottom:0;left:0}
  .compare__figure img{display:block;width:100%;height:100%;object-fit:cover}
  .compare__figure-before .compare__content{align-items:flex-start;right:auto;left:0;margin-right:auto}
  .compare__figure-before .compare__text{align-items:flex-start;text-align:left}
  .compare__figure-after .compare__content{align-items:flex-end;right:0;left:auto;margin-left:auto}
  .compare__figure-after .compare__text{align-items:flex-end;text-align:right}
  .compare__label{font-size:1.2rem;line-height:1.66;display:block;max-width:30rem;word-wrap:break-word;color:rgb(var(--color-foreground,42,42,42))}
  .compare__handle{width:2.6rem;height:4.35rem;display:flex;align-items:center;justify-content:center;background-color:rgb(var(--color-background,255,255,255));color:rgb(var(--color-foreground,42,42,42));border-radius:5rem;overflow:hidden}
  .compare__handle .icon-compare{width:1.575rem;height:3rem}
  @media(min-width:576px){.compare__handle{width:3.5rem;height:5.8rem}.compare__handle .icon-compare{width:2.1rem;height:4rem}}
  .compare__content{position:relative;max-width:100%;height:100%;display:flex;flex-direction:column;padding:2.4rem}
  @media(min-width:750px){.compare__content{padding:4rem;max-width:50%}}
  .compare__content--vertical-align-top{justify-content:flex-start}
  .compare__content--vertical-align-center{justify-content:center}
  .compare__content--vertical-align-bottom{justify-content:flex-end}
  .compare__content--vertical-align-space_between{justify-content:space-between}
  .compare__text{width:100%;display:flex;flex-direction:column;gap:1.6rem}
  .compare__heading{margin:0;padding:0;max-width:55rem}
  .compare__overlay{position:absolute;top:0;right:0;bottom:0;left:0;width:100%;height:100%;z-index:0;border-radius:var(--border-radius-block)}
  .compare__top{margin-bottom:2.4rem}
  @media screen and (min-width:750px){.compare__top{margin-bottom:3.2rem}}
  @media screen and (min-width:1200px){.compare__top{margin-bottom:5.6rem}}
  .compare .compare__heading__description{margin-bottom:0!important}
  .no-js .compare img-comparison-slider{visibility:visible}
  .no-js .compare img-comparison-slider:after{content:"";position:absolute;left:50%;top:50%;display:block;height:100%;width:.2rem;background-color:rgb(var(--color-background,255,255,255));transform:translate(-50%,-50%)}
  .no-js .compare img-comparison-slider .compare__figure{position:absolute;top:0;bottom:0;left:0;right:50%;width:50%}
  .no-js .compare img-comparison-slider .compare__figure[slot=second]{left:50%;right:0;display:block}
  .no-js .compare img-comparison-slider .compare__figure img{width:100%;height:100%;object-fit:cover}
  .no-js .compare .compare__handle{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);z-index:1}

  /* ============================================================
     Padding responsivo — idéntico a Pebblebee
  ============================================================ */
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}rem;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}rem;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_tablet }}rem;
      padding-bottom: {{ section.settings.padding_bottom_tablet }}rem;
    }
  }
  @media screen and (min-width: 1440px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_desktop }}rem;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}rem;
    }
  }

  /* ============================================================
     Fondo negro en mobile
  ============================================================ */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .compare {
      background-color: #000 !important;
    }
    #shopify-section-{{ section.id }} .compare__heading__subtitle,
    #shopify-section-{{ section.id }} .compare__heading__title,
    #shopify-section-{{ section.id }} .compare__heading__description {
      color: #fff !important;
    }
  }

  /* ============================================================
     Variables de sección
  ============================================================ */
  #shopify-section-{{ section.id }} {
    --border-radius-block: 12px;
    --color-overlay: 0, 0, 0;
  }

  /* ============================================================
     Container
  ============================================================ */
  #shopify-section-{{ section.id }} .container {
    width: 100%;
    padding-left: 2rem;
    padding-right: 2rem;
    margin-left: auto;
    margin-right: auto;
  }
  @media screen and (min-width: 1200px) {
    #shopify-section-{{ section.id }} .container {
      padding-left: 8rem;
      padding-right: 8rem;
    }
  }
  @media screen and (min-width: 1360px) {
    #shopify-section-{{ section.id }} .container {
      max-width: 1440px;
    }
  }

  /* ============================================================
     Tipografía — heading group
  ============================================================ */
  #shopify-section-{{ section.id }} .compare__heading__titles {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.2rem;
    margin-bottom: 1.6rem;
  }
  #shopify-section-{{ section.id }} .compare__heading__subtitle {
    font-family: Montserrat, sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: #fff;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1.4;
    margin: 0;
  }
  #shopify-section-{{ section.id }} .compare__heading__title {
    font-family: Poppins, sans-serif;
    font-size: 2.52rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .compare__heading__title { font-size: 2.94rem; }
  }
  @media screen and (min-width: 990px) {
    #shopify-section-{{ section.id }} .compare__heading__title { font-size: 3.36rem; }
  }
  @media screen and (min-width: 1360px) {
    #shopify-section-{{ section.id }} .compare__heading__title { font-size: 4.2rem; }
  }
  #shopify-section-{{ section.id }} .compare__heading__description {
    text-align: center;
    max-width: 70%;
    margin-left: auto;
    margin-right: auto;
    font-family: 'Source Sans Pro', sans-serif;
    font-size: 1.5rem;
    line-height: 1.6;
    color: #fff;
  }
  @media only screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .compare__heading__description { max-width: 100%; }
    #shopify-section-{{ section.id }} .compare__label {
      font-family: Montserrat, sans-serif !important;
      font-size: 0.9rem !important;
      font-weight: 500 !important;
      letter-spacing: 0.06em !important;
      text-transform: uppercase !important;
      line-height: 1.3 !important;
    }
    #shopify-section-{{ section.id }} .compare__heading.h3 {
      font-family: Poppins, sans-serif !important;
      font-size: 1.2rem !important;
      font-weight: 700 !important;
      max-width: 43% !important;
      line-height: 1.2 !important;
    }
  }

  /* ============================================================
     Label & heading dentro del slider — Desktop (≥750px)
  ============================================================ */
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .compare__label {
      font-family: Montserrat, sans-serif !important;
      font-size: 1.2rem !important;
      font-weight: 500 !important;
      letter-spacing: 0.06em !important;
      text-transform: uppercase !important;
      line-height: 1.66 !important;
      color: #2a2a2a !important;
    }
    #shopify-section-{{ section.id }} .compare__heading.h3 {
      font-family: Poppins, sans-serif !important;
      font-size: 2rem !important;
      font-weight: 700 !important;
      color: #2a2a2a !important;
      margin: 0 !important;
      max-width: 55rem !important;
      line-height: 1.2 !important;
    }
  }
  @media screen and (min-width: 990px) {
    #shopify-section-{{ section.id }} .compare__heading.h3 {
      font-size: 2.4rem !important;
    }
  }
</style>

<section class="compare section-{{ section.id }}-padding background" style="background-color: {{ section.settings.background_color }};">

  <div class="compare__top container">
    {%- if section.settings.subtitle != blank or section.settings.title != blank -%}
      <div class="compare__heading__titles titles titles--center">
        {%- if section.settings.subtitle != blank -%}
          <div class="compare__heading__subtitle subtitle">{{ section.settings.subtitle }}</div>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="compare__heading__title title h2 size--h2">{{ section.settings.title }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}
    {%- if section.settings.description != blank -%}
      <div class="compare__heading__description">{{ section.settings.description }}</div>
    {%- endif -%}
  </div>

  <div class="compare__wrapper container">
    <div
      class="compare__images"
      style="--padding-bottom-mobile: {{ section.settings.aspect_ratio }}%; --padding-bottom-desktop: {{ section.settings.aspect_ratio }}%;"
    >
      <img-comparison-slider>

        <!-- Slot FIRST (izquierda) -->
        <div class="compare__figure compare__figure-before color-background-1 background" slot="first">
          <div class="compare__figure-image">
            {%- if section.settings.image_1 != blank -%}
              <img
                src="{{ section.settings.image_1 | image_url: width: 1840 }}"
                alt="{{ section.settings.image_1.alt | escape }}"
                srcset="
                  {{ section.settings.image_1 | image_url: width: 400 }} 400w,
                  {{ section.settings.image_1 | image_url: width: 600 }} 600w,
                  {{ section.settings.image_1 | image_url: width: 900 }} 900w,
                  {{ section.settings.image_1 | image_url: width: 1200 }} 1200w,
                  {{ section.settings.image_1 | image_url: width: 1840 }} 1840w
                "
                width="{{ section.settings.image_1.width }}"
                height="{{ section.settings.image_1.height }}"
                loading="lazy"
              >
            {%- else -%}
              <img
                src="//pebblebee.com/cdn/shop/files/find-my_a602cec3-806e-4ad6-8001-d18b21732811.jpg?v=1752176553&width=1840"
                alt="Apple Find My"
                width="1840"
                height="1035"
                loading="lazy"
              >
            {%- endif -%}
            <div
              class="compare__overlay"
              style="background: linear-gradient(180deg, rgba(var(--color-overlay),0.051) 0, rgba(var(--color-overlay),0.051) 50%, rgba(var(--color-overlay),0.17) 100%);"
            ></div>
          </div>
          <div class="compare__content compare__content--vertical-align-center">
            {%- if section.settings.label_1 != blank -%}
              <div class="compare__label compare__label--left subtitle body-small">{{ section.settings.label_1 }}</div>
            {%- endif -%}
            {%- if section.settings.heading_1 != blank -%}
              <div class="compare__text">
                <h3 class="compare__heading h3">{{ section.settings.heading_1 }}</h3>
              </div>
            {%- endif -%}
          </div>
        </div>

        <!-- Slot SECOND (derecha) -->
        <div class="compare__figure compare__figure-after color-background-1 background" slot="second">
          <div class="compare__figure-image">
            {%- if section.settings.image_2 != blank -%}
              <img
                src="{{ section.settings.image_2 | image_url: width: 1280 }}"
                alt="{{ section.settings.image_2.alt | escape }}"
                srcset="
                  {{ section.settings.image_2 | image_url: width: 400 }} 400w,
                  {{ section.settings.image_2 | image_url: width: 600 }} 600w,
                  {{ section.settings.image_2 | image_url: width: 900 }} 900w,
                  {{ section.settings.image_2 | image_url: width: 1280 }} 1280w
                "
                width="{{ section.settings.image_2.width }}"
                height="{{ section.settings.image_2.height }}"
                loading="lazy"
              >
            {%- else -%}
              <img
                src="//pebblebee.com/cdn/shop/files/find-hub_11ffa509-4228-4cae-b408-ba325eca28d9.jpg?v=1752176567&width=1280"
                alt="Google Find Hub"
                width="1280"
                height="720"
                loading="lazy"
              >
            {%- endif -%}
            <div
              class="compare__overlay"
              style="background: linear-gradient(180deg, rgba(var(--color-overlay),0.051) 0, rgba(var(--color-overlay),0.051) 50%, rgba(var(--color-overlay),0.17) 100%);"
            ></div>
          </div>
          <div class="compare__content compare__content--vertical-align-center">
            {%- if section.settings.label_2 != blank -%}
              <div class="compare__label compare__label--right subtitle body-small">{{ section.settings.label_2 }}</div>
            {%- endif -%}
            {%- if section.settings.heading_2 != blank -%}
              <div class="compare__text">
                <h3 class="compare__heading h3">{{ section.settings.heading_2 }}</h3>
              </div>
            {%- endif -%}
          </div>
        </div>

        <!-- Handle -->
        <div class="compare__handle" slot="handle">
          <svg class="icon icon-compare" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M4.5 1.5L5.5 1.5L5.5 18.5L4.5 18.5L4.5 1.5ZM9.5 1.5L10.5 1.5L10.5 18.5L9.5 18.5L9.5 1.5ZM15.5 1.5L14.5 1.5L14.5 18.5L15.5 18.5L15.5 1.5Z" fill="currentColor"/>
          </svg>
        </div>

      </img-comparison-slider>
    </div>
  </div>

</section>

<script>
