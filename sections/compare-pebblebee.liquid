{% schema %}
{
  "name": "Image Comparison",
  "tag": "section",
  "class": "section-compare",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Encabezado"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Universal Compatibility"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Bigger Networks, Better Privacy"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descripción",
      "default": "We've partnered with both Apple & Google to develop, test, and certify our item finders to ensure they work seamlessly with the Find My network for iOS users or the Find Hub network for Android users."
    },
    {
      "type": "header",
      "content": "Imagen izquierda (slot: first)"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Imagen izquierda"
    },
    {
      "type": "text",
      "id": "label_1",
      "label": "Label",
      "default": "Apple Find My"
    },
    {
      "type": "text",
      "id": "heading_1",
      "label": "Heading",
      "default": "Rechargeable Item Finders for iOS"
    },
    {
      "type": "header",
      "content": "Imagen derecha (slot: second)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Imagen derecha"
    },
    {
      "type": "text",
      "id": "label_2",
      "label": "Label",
      "default": "Google's Find Hub"
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "Heading",
      "default": "Market Leading Item Finders for Android"
    },
    {
      "type": "header",
      "content": "Proporciones del slider"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        { "value": "56.25", "label": "16:9" },
        { "value": "66.67", "label": "3:2" },
        { "value": "75",    "label": "4:3" },
        { "value": "50",    "label": "2:1" },
        { "value": "100",   "label": "1:1" }
      ],
      "default": "56.25"
    },
    {
      "type": "header",
      "content": "Padding — Móvil"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0, "max": 16, "step": 0.4, "unit": "rem",
      "label": "Top",
      "default": 3.2
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0, "max": 16, "step": 0.4, "unit": "rem",
      "label": "Bottom",
      "default": 3.2
    },
    {
      "type": "header",
      "content": "Padding — Tablet (≥750px)"
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "min": 0, "max": 16, "step": 0.4, "unit": "rem",
      "label": "Top",
      "default": 4
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "min": 0, "max": 16, "step": 0.4, "unit": "rem",
      "label": "Bottom",
      "default": 4
    },
    {
      "type": "header",
      "content": "Padding — Desktop (≥1440px)"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0, "max": 16, "step": 0.4, "unit": "rem",
      "label": "Top",
      "default": 5.6
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0, "max": 16, "step": 0.4, "unit": "rem",
      "label": "Bottom",
      "default": 5.6
    }
  ],
  "presets": [
    {
      "name": "Image Comparison"
    }
  ]
}
{% endschema %}
