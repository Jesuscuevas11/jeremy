{{ 'section-image-gallery.css' | asset_url | stylesheet_tag }}
{{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}
<script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'image-gallery.js' | asset_url }}" defer="defer"></script>

<section class="image-gallery-section spaced-section" data-section-id="{{ section.id }}">
  <style>
    #shopify-section-{{ section.id }} {
      padding-top: 0;
      padding-bottom: 0; 
    }
    .image-gallery-section-{{ section.id }}-padding {
      padding-top: 6.4rem;
      padding-bottom: 6.4rem;
    }
    @media screen and (min-width: 750px) {
      .image-gallery-section-{{ section.id }}-padding {
        padding-top: 8.8rem;
        padding-bottom: 8.8rem;
      }
    }
    @media screen and (min-width: 1440px) {
      .image-gallery-section-{{ section.id }}-padding {
        padding-top: 14rem;
        padding-bottom: 14rem;
      }
    }
    {% for block in section.blocks %}
      .image-gallery-section-{{ section.id }}-padding .image-gallery__slide-{{ block.id }}::before {
        content: "";
        display: block;
        width: 0;
        padding-bottom: 56.25%;
      }
      @media screen and (min-width: 576px) {
        .image-gallery-section-{{ section.id }}-padding .image-gallery__slide-{{ block.id }}::before {
          content: "";
          display: block;
          width: 0;
          padding-bottom: 56.25%;
        }
      }
    {% endfor %}
  </style>

  <div class="image-gallery color-background-1 background image-gallery-section-{{ section.id }}-padding" style="background-color: #e2f2f7;">
    <div class="image-gallery__wrapper"
      data-autoplay="true"
      data-loop="true"
      data-navigation="true"
      data-pagination="true"
      data-slides-count="{{ section.blocks.size }}"
      data-free-mode="false"
    >
      <div class="image-gallery__slider-ratio">
      <div class="image-gallery__slider swiper">
        <div class="image-gallery__slider-wrapper swiper-wrapper">
          {% for block in section.blocks %}
            <div class="image-gallery__slide image-gallery__slide-{{ block.id }} swiper-slide"
              data-swiper-autoplay="5000"
              {{ block.shopify_attributes }}
            >
              {% if block.settings.image %}
                <img
                  src="{{ block.settings.image | image_url: width: 3000 }}"
                  alt="{{ block.settings.image.alt | escape }}"
                  srcset="
                    {{ block.settings.image | image_url: width: 550 }} 550w,
                    {{ block.settings.image | image_url: width: 720 }} 720w,
                    {{ block.settings.image | image_url: width: 990 }} 990w,
                    {{ block.settings.image | image_url: width: 1200 }} 1200w,
                    {{ block.settings.image | image_url: width: 1500 }} 1500w,
                    {{ block.settings.image | image_url: width: 1800 }} 1800w,
                    {{ block.settings.image | image_url: width: 2200 }} 2200w,
                    {{ block.settings.image | image_url: width: 3000 }} 3000w
                  "
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                  loading="lazy"
                  class="image-gallery__slide-image"
                  sizes="100vw"
                  {% if block.settings.image_position != blank %}
                    style="object-position: {{ block.settings.image_position }};"
                  {% endif %}
                >
              {% elsif block.settings.fallback_image_url != blank %}
                <img
                  src="{{ block.settings.fallback_image_url }}"
                  alt=""
                  width="3000"
                  height="1688"
                  loading="lazy"
                  class="image-gallery__slide-image"
                  sizes="100vw"
                  {% if block.settings.image_position != blank %}
                    style="object-position: {{ block.settings.image_position }};"
                  {% endif %}
                >
              {% endif %}
              <div class="image-gallery__slide-overlay" style="opacity: 0.0"></div>
            </div>
          {% endfor %}
        </div>

        <div class="no-js-hidden image-gallery__cursor next">
          <svg width="36" height="36" class="icon icon-arrow" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" focusable="false" role="presentation">
            <path d="M3 18L33 18M33 18L20.1429 6M33 18L20.1429 30" stroke="currentColor" stroke-width="2" stroke-linecap="square"/>
          </svg>
        </div>
      </div>
      </div>

      <div class="no-js-hidden image-gallery__pagination swiper-pagination"></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image Gallery",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "fallback_image_url",
          "label": "Fallback image URL (used if no image uploaded)"
        },
        {
          "type": "text",
          "id": "image_position",
          "label": "Image focal point (CSS object-position)",
          "placeholder": "e.g. 50% 50%"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Gallery",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "fallback_image_url": "https://pebblebee.com/cdn/shop/files/type_lifestyle_view_car-keys.png?v=1762378617"
          }
        },
        {
          "type": "slide",
          "settings": {
            "fallback_image_url": "https://pebblebee.com/cdn/shop/files/type_lifestyle_view_snowmobile.png?v=1770713081"
          }
        },
        {
