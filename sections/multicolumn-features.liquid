{{ 'section-multicolumn-features.css' | asset_url | stylesheet_tag }}

<section class="spaced-section multicolumn-features-section">
  <div class="page-width multicolumn-features-padding">

    <div class="multicolumn__header__titles titles titles--center">
      <span class="multicolumn__header__subtitle subtitle">{{ section.settings.subtitle }}</span>
      <h2 class="multicolumn__header__title title h2">{{ section.settings.title }}</h2>
    </div>

    <div class="multicolumn-grid">
      <div class="multicolumn-grid__wrapper multicolumn-grid__wrapper--4">

        <!-- Card 1: Global Range -->
        <div class="multicolumn-card color-background-1 multicolumn-card--with-paddings multicolumn-card--border">
          <div class="multicolumn-card__inner multicolumn-card__inner--hor-align-center multicolumn-card__inner--ver-align-top">
            <div class="multicolumn-card__inner-top">
              <div class="multicolumn-card__image-wrapper multicolumn-card__image-wrapper--icon multicolumn-card__image-wrapper--square multicolumn-card__image-wrapper--with-dm-image multicolumn-card__image-wrapper--with-border-radius">
                <img src="//pebblebee.com/cdn/shop/files/Global_Range_Light.png?v=1752138036" alt="Global Range" class="multicolumn-card__image" width="64" height="64" loading="lazy">
                <img src="//pebblebee.com/cdn/shop/files/Global_Range_Dark.png?v=1752138036" alt="Global Range" class="multicolumn-card__image multicolumn-card__image--dark" width="64" height="64" loading="lazy">
              </div>
            </div>
            <div class="multicolumn-card__inner-bottom">
              <p class="multicolumn-card__text body-small multicolumn-card__text--primary"><strong>Redes más grandes</strong> • Alcance global con Apple Find My y Find Hub de Google.</p>
            </div>
          </div>
        </div>

        <!-- Card 2: Location Privacy -->
        <div class="multicolumn-card color-background-1 multicolumn-card--with-paddings multicolumn-card--border">
          <div class="multicolumn-card__inner multicolumn-card__inner--hor-align-center multicolumn-card__inner--ver-align-top">
            <div class="multicolumn-card__inner-top">
              <div class="multicolumn-card__image-wrapper multicolumn-card__image-wrapper--icon multicolumn-card__image-wrapper--square multicolumn-card__image-wrapper--with-dm-image multicolumn-card__image-wrapper--with-border-radius">
                <img src="//pebblebee.com/cdn/shop/files/Location_Privacy_Light.png?v=1752138036" alt="Location Privacy" class="multicolumn-card__image" width="64" height="64" loading="lazy">
                <img src="//pebblebee.com/cdn/shop/files/Location_Privacy_Dark.png?v=1752138036" alt="Location Privacy" class="multicolumn-card__image multicolumn-card__image--dark" width="64" height="64" loading="lazy">
              </div>
            </div>
            <div class="multicolumn-card__inner-bottom">
              <p class="multicolumn-card__text body-small multicolumn-card__text--primary"><strong>Mejor privacidad</strong> • Encriptado de extremo a extremo, solo tu dispositivo ve tu ubicación.</p>
            </div>
          </div>
        </div>

        <!-- Card 3: Rechargeable -->
        <div class="multicolumn-card color-background-1 multicolumn-card--with-paddings multicolumn-card--border">
          <div class="multicolumn-card__inner multicolumn-card__inner--hor-align-center multicolumn-card__inner--ver-align-top">
            <div class="multicolumn-card__inner-top">
              <div class="multicolumn-card__image-wrapper multicolumn-card__image-wrapper--icon multicolumn-card__image-wrapper--square multicolumn-card__image-wrapper--with-dm-image multicolumn-card__image-wrapper--with-border-radius">
                <img src="//pebblebee.com/cdn/shop/files/Rechargeable_Light.png?v=1752138036" alt="Rechargeable Battery" class="multicolumn-card__image" width="64" height="64" loading="lazy">
                <img src="//pebblebee.com/cdn/shop/files/Rechargeable_Dark.png?v=1752138036" alt="Rechargeable Battery" class="multicolumn-card__image multicolumn-card__image--dark" width="64" height="64" loading="lazy">
              </div>
            </div>
            <div class="multicolumn-card__inner-bottom">
              <p class="multicolumn-card__text body-small multicolumn-card__text--primary"><strong>Batería recargable</strong> • Hasta 12 meses con una sola carga.</p>
            </div>
          </div>
        </div>

        <!-- Card 4: Phone Finder -->
        <div class="multicolumn-card color-background-1 multicolumn-card--with-paddings multicolumn-card--border">
          <div class="multicolumn-card__inner multicolumn-card__inner--hor-align-center multicolumn-card__inner--ver-align-top">
            <div class="multicolumn-card__inner-top">
              <div class="multicolumn-card__image-wrapper multicolumn-card__image-wrapper--icon multicolumn-card__image-wrapper--square multicolumn-card__image-wrapper--with-dm-image multicolumn-card__image-wrapper--with-border-radius">
                <img src="//pebblebee.com/cdn/shop/files/Phone_Finder_Light.png?v=1752138036" alt="Phone Finder" class="multicolumn-card__image" width="64" height="64" loading="lazy">
                <img src="//pebblebee.com/cdn/shop/files/Phone_Finder_Dark.png?v=1752138036" alt="Phone Finder" class="multicolumn-card__image multicolumn-card__image--dark" width="64" height="64" loading="lazy">
              </div>
            </div>
            <div class="multicolumn-card__inner-bottom">
              <p class="multicolumn-card__text body-small multicolumn-card__text--primary"><strong>Buscador de teléfono</strong> • Pulsa dos veces para encontrar tu teléfono desde tus llaves o cartera.</p>
            </div>
          </div>
        </div>

        <!-- Card 5: Alert -->
        <div class="multicolumn-card color-background-1 multicolumn-card--with-paddings multicolumn-card--border">
          <div class="multicolumn-card__inner multicolumn-card__inner--hor-align-center multicolumn-card__inner--ver-align-top">
            <div class="multicolumn-card__inner-top">
              <div class="multicolumn-card__image-wrapper multicolumn-card__image-wrapper--icon multicolumn-card__image-wrapper--square multicolumn-card__image-wrapper--with-dm-image multicolumn-card__image-wrapper--with-border-radius">
                <img src="//pebblebee.com/cdn/shop/files/Alert_Light.png?v=1752138036" alt="Alert" class="multicolumn-card__image" width="64" height="64" loading="lazy">
                <img src="//pebblebee.com/cdn/shop/files/Alert_Dark.png?v=1752138036" alt="Alert" class="multicolumn-card__image multicolumn-card__image--dark" width="64" height="64" loading="lazy">
              </div>
            </div>
            <div class="multicolumn-card__inner-bottom">
              <p class="multicolumn-card__text body-small multicolumn-card__text--primary"><strong>Alert</strong> • Transforma tu llavero en un salvavidas (Disponible solo en el Clip).</p>
            </div>
          </div>
        </div>

        <!-- Card 6: Multi-Sensory Alarms -->
        <div class="multicolumn-card color-background-1 multicolumn-card--with-paddings multicolumn-card--border">
          <div class="multicolumn-card__inner multicolumn-card__inner--hor-align-center multicolumn-card__inner--ver-align-top">
            <div class="multicolumn-card__inner-top">
              <div class="multicolumn-card__image-wrapper multicolumn-card__image-wrapper--icon multicolumn-card__image-wrapper--square multicolumn-card__image-wrapper--with-dm-image multicolumn-card__image-wrapper--with-border-radius">
                <img src="//pebblebee.com/cdn/shop/files/Multisensory_Alarms_Light.png?v=1752138036" alt="Multi-Sensory Alarms" class="multicolumn-card__image" width="64" height="64" loading="lazy">
                <img src="//pebblebee.com/cdn/shop/files/Multisensory_Alarms_Dark.png?v=1752138036" alt="Multi-Sensory Alarms" class="multicolumn-card__image multicolumn-card__image--dark" width="64" height="64" loading="lazy">
              </div>
            </div>
            <div class="multicolumn-card__inner-bottom">
              <p class="multicolumn-card__text body-small multicolumn-card__text--primary"><strong>Alarmas multisensoriales</strong> • LEDs brillantes y zumbador potente.</p>
            </div>
          </div>
        </div>

        <!-- Card 7: Waterproof -->
        <div class="multicolumn-card color-background-1 multicolumn-card--with-paddings multicolumn-card--border">
          <div class="multicolumn-card__inner multicolumn-card__inner--hor-align-center multicolumn-card__inner--ver-align-top">
            <div class="multicolumn-card__inner-top">
              <div class="multicolumn-card__image-wrapper multicolumn-card__image-wrapper--icon multicolumn-card__image-wrapper--square multicolumn-card__image-wrapper--with-dm-image multicolumn-card__image-wrapper--with-border-radius">
                <img src="//pebblebee.com/cdn/shop/files/Waterproof_Light.png?v=1752138036" alt="Water Resistance" class="multicolumn-card__image" width="64" height="64" loading="lazy">
                <img src="//pebblebee.com/cdn/shop/files/Waterproof_Dark.png?v=1752138036" alt="Water Resistance" class="multicolumn-card__image multicolumn-card__image--dark" width="64" height="64" loading="lazy">
              </div>
            </div>
            <div class="multicolumn-card__inner-bottom">
              <p class="multicolumn-card__text body-small multicolumn-card__text--primary"><strong>Resistencia al agua</strong> • Certificación IP66 para máxima protección.</p>
            </div>
          </div>
        </div>

        <!-- Card 8: Bluetooth -->
        <div class="multicolumn-card color-background-1 multicolumn-card--with-paddings multicolumn-card--border">
          <div class="multicolumn-card__inner multicolumn-card__inner--hor-align-center multicolumn-card__inner--ver-align-top">
            <div class="multicolumn-card__inner-top">
              <div class="multicolumn-card__image-wrapper multicolumn-card__image-wrapper--icon multicolumn-card__image-wrapper--square multicolumn-card__image-wrapper--with-dm-image multicolumn-card__image-wrapper--with-border-radius">
                <img src="//pebblebee.com/cdn/shop/files/Bluetooth_Light.png?v=1752138704" alt="Bluetooth Low Energy" class="multicolumn-card__image" width="64" height="64" loading="lazy">
                <img src="//pebblebee.com/cdn/shop/files/Bluetooth_Dark.png?v=1752138704" alt="Bluetooth Low Energy" class="multicolumn-card__image multicolumn-card__image--dark" width="64" height="64" loading="lazy">
              </div>
            </div>
            <div class="multicolumn-card__inner-bottom">
              <p class="multicolumn-card__text body-small multicolumn-card__text--primary"><strong>Bluetooth de bajo consumo</strong> • Mantente conectado sin agotar tu batería.</p>
            </div>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Multicolumn Features",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Built to Keep You Connected"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Every Feature, Thoughtfully Designed"
    }
  ],
  "presets": [
    {
      "name": "Multicolumn Features"
    }
  ]
}
{% endschema %}
