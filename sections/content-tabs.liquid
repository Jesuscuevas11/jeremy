{{ 'section-content-tabs.css' | asset_url | stylesheet_tag }}
{{ 'content-tabs.js' | asset_url | script_tag }}

{%- assign tab_ids = "tech-specs,description,whats-included,battery-life,requirements" | split: "," -%}

<div class="content-tabs-section color-background-1 background">
  <div class="content-tabs-section-padding">

    <div class="content-tabs__titles titles titles--center">
      <h2 class="content-tabs__title title h3">{{ section.settings.title }}</h2>
    </div>

    <div class="content-tabs__wrapper">
      <div class="content-tabs__tabs">
        <div class="content-tabs__tabs-wrapper content-tabs__tabs-wrapper--5 content-tabs__tabs-wrapper--equal">
          {%- for i in (1..5) -%}
            {%- assign tab_id = tab_ids[forloop.index0] -%}
            {%- assign tab_title_key = "tab" | append: forloop.index | append: "_title" -%}
            <div class="content-tabs__tab{% if forloop.first %} content-tabs__tab--active{% endif %} focus-inset" data-content-tab-id="#content-tab-{{ tab_id }}" tabindex="0">
              <span>{{ section.settings[tab_title_key] }}</span>
            </div>
          {%- endfor -%}
        </div>
      </div>

      {%- for i in (1..5) -%}
        {%- assign tab_id = tab_ids[forloop.index0] -%}
        {%- assign tab_num = forloop.index | append: "" -%}
        <div class="content-tabs__content content-tabs__content--2-column{% if forloop.first %} content-tabs__content--active animate{% endif %} left" data-content-tab-id="#content-tab-{{ tab_id }}">
          {%- for block in section.blocks -%}
            {%- if block.settings.tab == tab_num -%}
              <div class="content-tabs__content-block" {{ block.shopify_attributes }}>
                {%- if block.settings.title != blank -%}
                  <h4 class="content-tabs__content-title">{{ block.settings.title }}</h4>
                {%- endif -%}
                {%- if block.settings.content != blank -%}
                  <div class="content-tabs__content-text rte rte__container">{{ block.settings.content }}</div>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endfor -%}

    </div>
  </div>
</div>


{% schema %}
{
  "name": "Pestañas de Contenido",
  "max_blocks": 50,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título principal",
      "default": "Especificaciones Técnicas"
    },
    {
      "type": "text",
      "id": "tab1_title",
      "label": "Nombre pestaña 1",
      "default": "Especificaciones"
    },
    {
      "type": "text",
      "id": "tab2_title",
      "label": "Nombre pestaña 2",
      "default": "Descripción"
    },
    {
      "type": "text",
      "id": "tab3_title",
      "label": "Nombre pestaña 3",
      "default": "Qué incluye"
    },
    {
      "type": "text",
      "id": "tab4_title",
      "label": "Nombre pestaña 4",
      "default": "Vida de la batería"
    },
    {
      "type": "text",
      "id": "tab5_title",
      "label": "Nombre pestaña 5",
      "default": "Requisitos"
    }
  ],
  "blocks": [
    {
      "type": "spec",
      "name": "Ítem de contenido",
      "settings": [
        {
          "type": "select",
          "id": "tab",
          "label": "Pestaña",
          "options": [
            { "value": "1", "label": "Pestaña 1 – Especificaciones" },
            { "value": "2", "label": "Pestaña 2 – Descripción" },
            { "value": "3", "label": "Pestaña 3 – Qué incluye" },
            { "value": "4", "label": "Pestaña 4 – Batería" },
            { "value": "5", "label": "Pestaña 5 – Requisitos" }
          ],
          "default": "1"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título del ítem"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Contenido"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pestañas de Contenido"
    }
  ]
}
{% endschema %}
