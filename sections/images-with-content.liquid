{{ 'section-images-with-content.css' | asset_url | stylesheet_tag }}

<style>
  .images-with-content-section-padding {
    padding-top: 2.4rem;
    padding-bottom: 5.6rem;
  }
  @media screen and (min-width: 750px) {
    .images-with-content-section-padding {
      padding-top: 3.2rem;
      padding-bottom: 7.2rem;
    }
  }
  @media screen and (min-width: 1440px) {
    .images-with-content-section-padding {
      padding-top: 3.2rem;
      padding-bottom: 11rem;
    }
  }

  /* Video play button overlay */
  .iwc-video-wrapper {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    cursor: pointer;
  }
  .iwc-play-button {
    position: absolute;
    bottom: 16px;
    left: 16px;
    width: 64px;
    height: 64px;
    z-index: 2;
    pointer-events: none;
  }
  @media screen and (min-width: 750px) {
    .iwc-play-button {
      width: 80px;
      height: 80px;
      bottom: 20px;
      left: 20px;
    }
  }
  .iwc-play-button svg {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.4));
  }

  /* Video modal */
  .iwc-video-modal {
    position: fixed;
    z-index: 9999;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.85);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .iwc-video-modal.hidden {
    display: none;
  }
  .iwc-video-modal__content {
    position: relative;
    width: 90%;
    max-width: 900px;
    aspect-ratio: 16 / 9;
    background: #000;
    border-radius: 12px;
    overflow: hidden;
  }
  .iwc-video-modal__content iframe {
    width: 100%;
    height: 100%;
    border: none;
  }
  .iwc-video-modal__close {
    position: absolute;
    top: 12px;
    right: 16px;
    font-size: 32px;
    line-height: 1;
    background: none;
    border: none;
    color: #fff;
    cursor: pointer;
    z-index: 10;
    padding: 0;
    opacity: 0.8;
  }
  .iwc-video-modal__close:hover {
    opacity: 1;
  }
</style>

<div class="images-with-content-section spaced-section">
  <div class="images-with-content color-background-1 background images-with-content-section-padding">
    <div class="page-width">

      <div class="images-with-content__heading-group__titles titles titles--center">
        <div class="images-with-content__heading-group__subtitle subtitle">{{ section.settings.subtitle }}</div>
        <h2 class="images-with-content__heading-group__title title h2">{{ section.settings.title }}</h2>
      </div>

      <div class="images-with-content-main content">

        {%- assign fallback_img1 = 'https://pebblebee.com/cdn/shop/files/type_hero-video_view_girl-winter.png?v=1770711426' -%}
        {%- assign fallback_img2 = 'https://pebblebee.com/cdn/shop/files/Product_Family_-_Freeze_Frame_text_34bd4fe6-2e13-45ae-9e94-41b87af23b5b.png?v=1770711823' -%}
        {%- assign vimeo_id = section.settings.vimeo_id | default: '1159913822' -%}

        <div class="images-with-content-images images-with-content-images--both-images" style="--images-aspect-ratio: {{ section.settings.images_aspect_ratio }}">

          <!-- Left: video poster with play button -->
          <div class="images-with-content-img-wrapper images-with-content-img-wrapper--1">
            <div class="iwc-video-wrapper" onclick="iwcOpenModal('{{ vimeo_id }}')">
              {%- if section.settings.image_1 != blank -%}
                <img
                  src="{{ section.settings.image_1 | image_url: width: 1500 }}"
                  alt="{{ section.settings.image_1.alt | escape }}"
                  srcset="
                    {{ section.settings.image_1 | image_url: width: 375 }} 375w,
                    {{ section.settings.image_1 | image_url: width: 750 }} 750w,
                    {{ section.settings.image_1 | image_url: width: 1000 }} 1000w,
                    {{ section.settings.image_1 | image_url: width: 1500 }} 1500w
                  "
                  width="{{ section.settings.image_1.width }}"
                  height="{{ section.settings.image_1.height }}"
                  loading="lazy"
                  style="object-fit: cover; width: 100%; height: 100%; display: block;"
                >
              {%- else -%}
                <img
                  src="{{ fallback_img1 }}"
                  alt="Evercolor Drop"
                  width="3000"
                  height="3000"
                  loading="lazy"
                  style="object-fit: cover; width: 100%; height: 100%; display: block;"
                >
              {%- endif -%}
              <div class="iwc-play-button">
                <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="50" cy="50" r="48" stroke="white" stroke-width="4" fill="rgba(0,0,0,0.55)"/>
                  <polygon points="40,30 72,50 40,70" fill="white"/>
                </svg>
              </div>
            </div>
          </div>

          <!-- Right: static image -->
          <div class="images-with-content-img-wrapper images-with-content-img-wrapper--2">
            {%- if section.settings.image_2 != blank -%}
              <img
                src="{{ section.settings.image_2 | image_url: width: 1500 }}"
                alt="{{ section.settings.image_2.alt | escape }}"
                srcset="
                  {{ section.settings.image_2 | image_url: width: 375 }} 375w,
                  {{ section.settings.image_2 | image_url: width: 750 }} 750w,
                  {{ section.settings.image_2 | image_url: width: 1000 }} 1000w,
                  {{ section.settings.image_2 | image_url: width: 1500 }} 1500w
                "
                width="{{ section.settings.image_2.width }}"
                height="{{ section.settings.image_2.height }}"
                loading="lazy"
                style="object-fit: cover"
                class="images-with-content-img images-with-content-img--2"
              >
            {%- else -%}
              <img
                src="{{ fallback_img2 }}"
                alt="Freeze Frame"
                width="1920"
                height="1080"
                loading="lazy"
                style="object-fit: cover"
                class="images-with-content-img images-with-content-img--2"
              >
            {%- endif -%}
          </div>

        </div>

        <div class="images-with-content-text">
          <div class="images-with-content-text__inner-header">
            <span class="images-with-content-text__subheading subtitle">{{ section.settings.text_subheading }}</span>
            <h2 class="images-with-content-text__heading h2">{{ section.settings.text_heading }}</h2>
          </div>
          <div class="images-with-content-text__inner-content">
            <div class="images-with-content-text__text images-with-content-text__text--1 body-normal rte rte__container">
              {{ section.settings.text_content }}
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<!-- Video modal -->
<div id="iwc-video-modal-{{ section.id }}" class="iwc-video-modal hidden" onclick="iwcCloseModal('{{ section.id }}')">
  <div class="iwc-video-modal__content" onclick="event.stopPropagation()">
    <iframe id="iwc-iframe-{{ section.id }}" src="" allow="autoplay; fullscreen" allowfullscreen></iframe>
    <button class="iwc-video-modal__close" onclick="iwcCloseModal('{{ section.id }}')" aria-label="Close video">&times;</button>
  </div>
</div>

<script>
  function iwcOpenModal(vimeoId) {
    var sectionId = '{{ section.id }}';
    var modal = document.getElementById('iwc-video-modal-' + sectionId);
    var iframe = document.getElementById('iwc-iframe-' + sectionId);
    iframe.src = 'https://player.vimeo.com/video/' + vimeoId + '?autoplay=1';
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }
  function iwcCloseModal(sectionId) {
    var modal = document.getElementById('iwc-video-modal-' + sectionId);
    var iframe = document.getElementById('iwc-iframe-' + sectionId);
    iframe.src = '';
    modal.classList.add('hidden');
    document.body.style.overflow = '';
  }
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      iwcCloseModal('{{ section.id }}');
    }
  });
</script>

{% schema %}
{
  "name": "Images with Content",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Top subtitle",
      "default": "New Evercolor Drop"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Top title",
      "default": "Limited Colors. Never Repeated."
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1 — left (video poster)"
    },
    {
      "type": "text",
      "id": "vimeo_id",
      "label": "Vimeo video ID",
      "default": "1159913822",
      "info": "Only the numeric ID, e.g. 1159913822"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2 — right"
    },
    {
      "type": "text",
      "id": "images_aspect_ratio",
      "label": "Images aspect ratio",
      "default": "2/1"
    },
    {
      "type": "text",
      "id": "text_subheading",
      "label": "Text subheading",
      "default": "About The Drop"
    },
    {
      "type": "text",
      "id": "text_heading",
      "label": "Text heading",
      "default": "Subzero & Hot Coral"
    },
    {
      "type": "richtext",
      "id": "text_content",
      "label": "Text content",
      "default": "<p>Temperature is an invisible force that shapes your instincts long before you're aware of it. Freeze Frame explores how temperature becomes memory and memory becomes intuition. More than a colorway, Freeze Frame is a reminder that the unseen forces often shape us the most. <strong>When they're gone, they're gone.</strong></p>"
    }
  ],
  "presets": [
    {
      "name": "Images with Content"
    }
  ]
}
{% endschema %}
